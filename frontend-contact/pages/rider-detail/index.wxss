.detail-container {
  min-height: 100vh;
  background: #F0F4F8;
}

.contact-bar {
  background: linear-gradient(135deg, #4FC3F7 0%, #29B6F6 100%);
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-info {
  display: flex;
  flex-direction: column;
}

.contact-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.contact-relation {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.call-icon {
  font-size: 36rpx;
}

.tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #4FC3F7;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #666666;
}

.tab-item.active .tab-text {
  color: #4FC3F7;
  font-weight: 500;
}

.content-section {
  padding: 24rpx;
}

.map-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  position: relative;
}

.map-component {
  width: 100%;
  height: 400rpx;
}

.map-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  padding: 40rpx 24rpx 24rpx;
}

.map-info {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 20rpx;
}

.map-address, .map-time {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.map-address:last-child, .map-time:last-child {
  margin-bottom: 0;
}

.address-icon, .time-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.address-text, .time-text {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.action-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.alarm-list, .event-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.alarm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.alarm-item:last-child {
  border-bottom: none;
}

.alarm-left {
  display: flex;
  flex: 1;
}

.alarm-type {
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  min-width: 80rpx;
  text-align: center;
}

.alarm-type.high {
  background: #EF5350;
}

.alarm-type.medium {
  background: #FFA726;
}

.alarm-type.low {
  background: #66BB6A;
}

.alarm-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alarm-message {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.alarm-time {
  font-size: 22rpx;
  color: #999999;
}

.alarm-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.alarm-status.open {
  background: #FFEBEE;
  color: #EF5350;
}

.alarm-status.acked {
  background: #FFF3E0;
  color: #FFA726;
}

.alarm-status.resolved {
  background: #E8F5E9;
  color: #66BB6A;
}

.event-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.event-item:last-child {
  border-bottom: none;
}

.event-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.event-type {
  font-size: 24rpx;
  color: #4FC3F7;
  background: #E3F2FD;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.event-time {
  font-size: 22rpx;
  color: #999999;
}

.event-desc {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.event-location {
  display: flex;
  align-items: center;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 24rpx;
  color: #999999;
}

.report-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.report-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.report-date {
  font-size: 24rpx;
  color: #999999;
}

.score-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4FC3F7 0%, #29B6F6 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.score-info {
  flex: 1;
  display: flex;
  justify-content: space-around;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.score-num.risk-high {
  color: #EF5350;
}

.score-num.risk-medium {
  color: #FFA726;
}

.score-num.risk-low {
  color: #66BB6A;
}

.score-name {
  font-size: 24rpx;
  color: #999999;
}

.behavior-section {
  margin-bottom: 24rpx;
}

.behavior-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.behavior-grid {
  display: flex;
  flex-wrap: wrap;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx;
}

.behavior-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.behavior-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #4FC3F7;
  margin-bottom: 8rpx;
}

.behavior-label {
  font-size: 22rpx;
  color: #999999;
}

.summary-section {
  margin-bottom: 24rpx;
}

.summary-title, .suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.summary-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.suggestion-list {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestion-item {
  display: flex;
  margin-bottom: 16rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-num {
  font-size: 26rpx;
  color: #4FC3F7;
  font-weight: 500;
  margin-right: 12rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}