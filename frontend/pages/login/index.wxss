.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4FC3F7 0%, #81D4FA 40%, #F0F4F8 100%);
  padding: 100rpx 40rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 卡通装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 120rpx;
  right: -80rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 80rpx;
  left: -60rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
  animation: fadeIn 0.8s ease-out;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.85) 100%);
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(79, 195, 247, 0.3);
  position: relative;
}

.logo::before {
  content: '⭐';
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 32rpx;
  color: #FFCC80;
}

.logo-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.login-form {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(79, 195, 247, 0.15);
  animation: fadeIn 1s ease-out;
  position: relative;
}

.login-form::before {
  content: '';
  position: absolute;
  top: -20rpx;
  left: 40rpx;
  right: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4FC3F7, #81D4FA, #B3E5FC);
  border-radius: 3rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #F0F4F8 0%, #FFFFFF 100%);
  border-radius: 48rpx;
  padding: 0 36rpx;
  font-size: 30rpx;
  color: #37474F;
  box-sizing: border-box;
  border: 2rpx solid #E1E5E9;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #4FC3F7;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.15);
}

.input::placeholder {
  color: #B0BEC5;
}

.code-item {
  display: flex;
  gap: 24rpx;
}

.code-input {
  flex: 1;
}

.get-code-btn {
  width: 200rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4FC3F7 0%, #81D4FA 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  outline: none;
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.2);
  transition: all 0.3s ease;
}

.get-code-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.get-code-btn[disabled] {
  background: linear-gradient(135deg, #CFD8DC 0%, #B0BEC5 100%);
  color: #FFFFFF;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.login-tips {
  text-align: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #78909C;
  line-height: 1.6;
}

.link {
  color: #4FC3F7;
  font-weight: 500;
}

.login-bottom {
  margin-top: 60rpx;
  text-align: center;
}

.wechat-login {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 44rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.85) 100%);
  border-radius: 48rpx;
  margin-bottom: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #37474F;
  box-shadow: 0 6rpx 20rpx rgba(79, 195, 247, 0.15);
  transition: all 0.3s ease;
}

.wechat-login:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.wechat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.role-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.role-btns {
  display: flex;
  gap: 12rpx;
}

.role-btn {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
  font-weight: 500;
}

.role-btn:active {
  transform: scale(0.95);
}

.role-btn.active {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  color: #4FC3F7;
  box-shadow: 0 4rpx 12rpx rgba(255, 255, 255, 0.3);
}

.password-input-wrap {
  position: relative;
}

.toggle-password {
  position: absolute;
  right: 36rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: #78909C;
  padding: 8rpx 16rpx;
  background: rgba(240, 244, 248, 0.8);
  border-radius: 20rpx;
}

.toggle-password:active {
  background: rgba(79, 195, 247, 0.1);
  color: #4FC3F7;
}

.password-strength {
  margin-top: -20rpx;
  margin-bottom: 16rpx;
  padding: 0 16rpx;
}

.strength-text {
  font-size: 24rpx;
  color: #78909C;
  margin-bottom: 8rpx;
}

.strength-bar {
  height: 8rpx;
  background: #E1E5E9;
  border-radius: 4rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.register-btn-wrap {
  margin-top: 20rpx;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #FFFFFF;
  color: #4FC3F7;
  border: 2rpx solid #4FC3F7;
  border-radius: 48rpx;
  transition: all 0.3s ease;
}

.register-btn:active {
  background: rgba(79, 195, 247, 0.05);
  transform: scale(0.98);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}