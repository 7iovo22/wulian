.page-container {
  min-height: 100vh;
  background-color: #F0F4F8;
  padding-bottom: 160rpx;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #4FC3F7;
}

.navbar-status-bar {
  height: var(--status-bar-height, 44px);
}

.navbar-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.navbar-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
}

.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.navbar-placeholder {
  width: 80rpx;
}

.header {
  background: linear-gradient(135deg, #4FC3F7 0%, #0288D1 100%);
  padding: 160rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.avatar-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.user-phone {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.logout-section {
  padding: 40rpx;
  margin-top: 40rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E53935;
  border-radius: 48rpx;
  color: #E53935;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 40rpx;
}

.nav-item.active .nav-icon {
  color: #4FC3F7;
}

.nav-item.active .nav-text {
  color: #4FC3F7;
  font-weight: 500;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  color: #999999;
}

.nav-text {
  font-size: 24rpx;
  color: #999999;
}