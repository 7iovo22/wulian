.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(180deg, #1E90FF 0%, #00BFFF 100%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.user-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.safety-score-card {
  background: #FFFFFF;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.score-ring {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-inner {
  width: 160rpx;
  height: 160rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1E90FF;
}

.score-label {
  font-size: 24rpx;
  color: #999999;
}

.score-info {
  display: flex;
  justify-content: space-around;
}

.score-item {
  text-align: center;
}

.score-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.score-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 5rpx;
}

.risk-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #1E90FF;
}

.risk-scroll {
  white-space: nowrap;
}

.risk-cards {
  display: inline-flex;
  gap: 20rpx;
}

.risk-card {
  width: 320rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: inline-block;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.risk-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.risk-type {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
}

.risk-time {
  font-size: 22rpx;
  color: #999999;
}

.risk-content {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
  white-space: normal;
}

.risk-location {
  font-size: 22rpx;
  color: #999999;
}

.quick-actions {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.action-grid {
  display: flex;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.sos {
  background: linear-gradient(135deg, #DC143C 0%, #FF4444 100%);
}

.action-icon.health {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.action-icon.location {
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
}

.action-icon.report {
  background: linear-gradient(135deg, #32CD32 0%, #90EE90 100%);
}

.icon-text {
  font-size: 36rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.device-status-card {
  margin: 0 20rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
}

.device-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.device-icon-wrap {
  position: relative;
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
}

.device-status-dot {
  position: absolute;
  bottom: 5rpx;
  right: 5rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999999;
}

.device-status-dot.online {
  background: #32CD32;
}

.device-status-dot.offline {
  background: #999999;
}

.device-info {
  flex: 1;
  margin-left: 20rpx;
}

.device-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.device-status-text {
  font-size: 24rpx;
  color: #999999;
}

.device-battery {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.battery-bar {
  width: 80rpx;
  height: 12rpx;
  background: #E8F4FC;
  border-radius: 6rpx;
  overflow: hidden;
}

.battery-fill {
  height: 100%;
  background: linear-gradient(90deg, #1E90FF 0%, #00BFFF 100%);
  border-radius: 6rpx;
}

.battery-text {
  font-size: 24rpx;
  color: #666666;
}

.device-data {
  display: flex;
  justify-content: space-around;
}

.data-item {
  text-align: center;
}

.data-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.data-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}

.daily-report {
  padding: 0 20rpx;
}

.report-card {
  display: flex;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 15rpx;
}

.report-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.report-icon {
  font-size: 40rpx;
}

.report-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.report-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.report-label {
  font-size: 22rpx;
  color: #999999;
}

.report-suggestion {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestion-icon {
  font-size: 32rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.5;
}