.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  position: relative;
}

.header::after {
  content: '';
  position: absolute;
  top: 20rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.user-status {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.header-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.safety-score-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  margin: -40rpx 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 44rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  animation: fadeIn 0.6s ease-out;
}

.safety-score-card::before {
  content: '⭐';
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 28rpx;
  color: var(--color-cute-orange);
  opacity: 0.6;
}

.score-ring {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-inner {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F4F8 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.score-value {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.score-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.score-info {
  display: flex;
  justify-content: space-around;
}

.score-item {
  text-align: center;
}

.score-num {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.score-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  font-weight: 500;
}

.risk-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
}

.section-more {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.risk-scroll {
  white-space: nowrap;
}

.risk-cards {
  display: inline-flex;
  gap: 24rpx;
}

.risk-card {
  width: 320rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  display: inline-block;
  box-shadow: var(--shadow-light);
  position: relative;
}

.risk-card::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.3;
}

.risk-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.risk-type {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.risk-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.risk-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  white-space: normal;
  line-height: 1.5;
}

.risk-location {
  font-size: 24rpx;
  color: var(--color-text-disabled);
}

.quick-actions {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.action-grid {
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: var(--shadow-light);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.action-icon:active {
  transform: scale(0.9);
}

.action-icon.sos {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
}

.action-icon.health {
  background: linear-gradient(135deg, var(--color-cute-orange) 0%, var(--color-warning-light) 100%);
}

.action-icon.location {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
}

.action-icon.report {
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
}

.icon-text {
  font-size: 36rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.device-status-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-light);
}

.device-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.device-icon-wrap {
  position: relative;
}

.device-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  box-shadow: var(--shadow-light);
}

.device-status-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--color-text-disabled);
  border: 2rpx solid #FFFFFF;
}

.device-status-dot.online {
  background: var(--color-success);
}

.device-status-dot.offline {
  background: var(--color-text-disabled);
}

.device-info {
  flex: 1;
  margin-left: 24rpx;
}

.device-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.device-status-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.device-battery {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.battery-bar {
  width: 88rpx;
  height: 14rpx;
  background: var(--color-bg-tertiary);
  border-radius: 7rpx;
  overflow: hidden;
}

.battery-fill {
  height: 100%;
  background: var(--color-primary-gradient);
  border-radius: 7rpx;
}

.battery-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.device-data {
  display: flex;
  justify-content: space-around;
}

.data-item {
  text-align: center;
}

.data-value {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.data-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  font-weight: 500;
}

.daily-report {
  padding: 0 24rpx;
}

.report-card {
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-light);
}

.report-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.report-icon {
  font-size: 44rpx;
}

.report-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.report-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.report-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.report-suggestion {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, var(--color-cute-orange) 0%, var(--color-warning-light) 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-light);
}

.suggestion-icon {
  font-size: 32rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #FFFFFF;
  line-height: 1.6;
  font-weight: 500;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}