.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  box-shadow: var(--shadow-light);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: var(--color-text-primary);
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.placeholder {
  width: 60rpx;
}

.detail-content {
  padding: 20rpx;
}

.section-card {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 25rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  flex: 1;
}

.ai-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.ai-badge.active {
  background: rgba(156, 39, 176, 0.1);
  color: #9C27B0;
}

.ai-badge.mock {
  background: rgba(120, 144, 156, 0.1);
  color: #78909C;
}

.save-btn {
  padding: 8rpx 20rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.analysis-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.action-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.action-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.action-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.action-status {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.action-status.completed {
  background: var(--color-success);
  color: #fff;
}

.action-status.pending {
  background: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
}

.draft-textarea {
  width: 100%;
  height: 300rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.draft-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.draft-count {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.report-date {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.daily-report {
  padding-top: 10rpx;
}

.report-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.summary-card {
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: 25rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.summary-value.warning {
  color: var(--color-warning);
}

.summary-value.success {
  color: var(--color-success);
}

.summary-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.summary-unit {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.report-section {
  margin-bottom: 25rpx;
}

.report-section:last-child {
  margin-bottom: 0;
}

.report-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 15rpx;
}

.health-stats {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.health-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.health-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.health-value {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.event-stats {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.event-stat {
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 15rpx 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.event-icon {
  font-size: 32rpx;
}

.event-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
}

.event-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.event-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.suggestion-item {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.suggestion-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 12rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}