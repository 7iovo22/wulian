.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 30%, var(--color-bg-secondary) 100%);
  position: relative;
  overflow: hidden;
}

/* 卡通装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 100rpx;
  right: -60rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 100rpx;
  left: -40rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.bind-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: transparent;
  position: relative;
  z-index: 10;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.35);
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.placeholder {
  width: 60rpx;
}

.bind-content {
  padding: 30rpx;
  position: relative;
  z-index: 10;
}

.device-scan {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.6s ease-out;
  position: relative;
  overflow: hidden;
}

.device-scan::before {
  content: '🔍';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 32rpx;
  opacity: 0.3;
}

.scan-circle {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 30rpx;
  position: relative;
  background: var(--color-primary-gradient);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(79, 195, 247, 0.4);
}

.scan-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

.scan-ring:nth-child(2) {
  animation-delay: 0.5s;
}

.scan-ring:nth-child(3) {
  animation-delay: 1s;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.device-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFFFFF;
  padding: 10rpx;
  box-sizing: border-box;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.scan-tips {
  color: var(--color-text-primary);
  font-size: 28rpx;
  font-weight: 500;
  position: relative;
  z-index: 5;
}

.device-list {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.7s ease-out;
  position: relative;
  overflow: hidden;
}

.device-list::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.15;
}

.section-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
  font-weight: 500;
  position: relative;
  z-index: 5;
}

.device-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
  z-index: 5;
  transition: all 0.3s ease;
}

.device-item:last-child {
  border-bottom: none;
}

.device-item:active {
  background: var(--color-bg-secondary);
}

.device-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.device-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow-light);
}

.device-detail {
  display: flex;
  flex-direction: column;
}

.device-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.device-sn {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 5rpx;
  font-weight: 500;
}

.device-signal {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.signal-icon {
  color: var(--color-success);
  font-size: 24rpx;
}

.signal-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.bind-form {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.8s ease-out;
  position: relative;
  overflow: hidden;
}

.bind-form::before {
  content: '📝';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 28rpx;
  opacity: 0.3;
}

.form-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  position: relative;
  z-index: 5;
  letter-spacing: 1rpx;
}

.form-item {
  margin-bottom: 25rpx;
  position: relative;
  z-index: 5;
}

.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-bg-secondary) 100%);
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--color-border-light);
  color: var(--color-text-primary);
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-light);
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  border-radius: 48rpx;
  border: none;
  box-shadow: var(--shadow-medium);
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
  position: relative;
}

.bind-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-light);
}

.bind-btn::before {
  content: '✨';
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
}

.bind-btn[disabled] {
  background: linear-gradient(135deg, var(--color-bg-tertiary) 0%, var(--color-border) 100%);
  color: var(--color-text-disabled);
  box-shadow: none;
}

.bind-help {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: var(--shadow-light);
  animation: fadeIn 0.9s ease-out;
  position: relative;
  overflow: hidden;
}

.bind-help::before {
  content: '💡';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 28rpx;
  opacity: 0.3;
}

.help-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  position: relative;
  z-index: 5;
  line-height: 1.6;
}

.help-icon {
  width: 36rpx;
  height: 36rpx;
  background: var(--color-primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFFFFF;
  box-shadow: var(--shadow-light);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}