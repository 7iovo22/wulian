<view class="container">
  <view class="bind-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">设备绑定</view>
    <view class="placeholder"></view>
  </view>

  <view class="bind-content">
    <view class="device-scan">
      <view class="scan-circle">
        <view class="scan-ring"></view>
        <image src="https://picsum.photos/100/100" mode="aspectFill" class="device-icon"></image>
      </view>
      <view class="scan-tips">{{scanStatus}}</view>
    </view>

    <view class="device-list" wx:if="{{deviceList.length > 0}}">
      <view class="section-title">附近设备</view>
      <view 
        class="device-item" 
        wx:for="{{deviceList}}" 
        wx:key="deviceSn"
        bindtap="selectDevice"
        data-device="{{item}}"
      >
        <view class="device-info">
          <image src="https://picsum.photos/60/60" mode="aspectFill" class="device-avatar"></image>
          <view class="device-detail">
            <view class="device-name">{{item.deviceName}}</view>
            <view class="device-sn">设备编号: {{item.deviceSn}}</view>
          </view>
        </view>
        <view class="device-signal">
          <text class="signal-icon">◉</text>
          <text class="signal-text">{{item.signal}}%</text>
        </view>
      </view>
    </view>

    <view class="bind-form">
      <view class="form-title">手动输入设备信息</view>
      <view class="form-item">
        <text class="form-label">设备序列号</text>
        <input 
          class="form-input" 
          placeholder="请输入设备序列号" 
          bindinput="onDeviceSnInput"
          value="{{deviceSn}}"
        />
      </view>
      <view class="form-item">
        <text class="form-label">绑定码</text>
        <input 
          class="form-input" 
          placeholder="请输入绑定码" 
          bindinput="onBindCodeInput"
          value="{{bindCode}}"
        />
      </view>
    </view>

    <button class="btn-primary bind-btn" bindtap="bindDevice" disabled="{{!canBind}}">
      绑定设备
    </button>

    <view class="bind-help">
      <view class="help-item">
        <text class="help-icon">?</text>
        <text class="help-text">如何获取绑定码?</text>
      </view>
      <view class="help-item">
        <text class="help-icon">?</text>
        <text class="help-text">设备序列号在哪里?</text>
      </view>
    </view>
  </view>
</view>