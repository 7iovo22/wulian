.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  box-shadow: var(--shadow-light);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: var(--color-text-primary);
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.placeholder {
  width: 60rpx;
}

.detail-content {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.event-card {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
}

.event-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 25rpx;
}

.event-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.event-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.type-tag {
  align-self: flex-start;
  padding: 8rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.event-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.risk-badge {
  padding: 8rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.event-meta {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.meta-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-badge.open {
  background: rgba(255, 140, 0, 0.1);
  color: #FF8C00;
}

.status-badge.acked {
  background: rgba(30, 144, 255, 0.1);
  color: #1E90FF;
}

.status-badge.resolved {
  background: rgba(50, 205, 50, 0.1);
  color: #32CD32;
}

.status-badge.cancelled {
  background: rgba(120, 144, 156, 0.1);
  color: #78909C;
}

.section-card {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 25rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.telemetry-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.telemetry-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.telemetry-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.telemetry-info {
  display: flex;
  flex-direction: column;
}

.telemetry-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.telemetry-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 30rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.timeline-line {
  position: absolute;
  left: 7rpx;
  width: 2rpx;
  background: var(--color-border-light);
  margin-top: 24rpx;
}

.timeline-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.timeline-event {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: bold;
}

.timeline-data {
  font-size: 22rpx;
  color: var(--color-text-disabled);
  padding-top: 5rpx;
}

.data-label {
  color: var(--color-text-disabled);
}

.data-value {
  color: var(--color-text-secondary);
}

.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.recommendation-item {
  display: flex;
  gap: 15rpx;
  align-items: flex-start;
}

.rec-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--color-success);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.rec-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.85;
}

.action-btn.secondary {
  background: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
}

.btn-icon {
  font-size: 32rpx;
}