<wxs module="format">
var formatNumber = function(value) {
  if (value === null || value === undefined || value === '') {
    return '--';
  }
  var num = parseFloat(value);
  return isNaN(num) ? '--' : value;
};

var formatText = function(value, fieldName) {
  fieldName = fieldName || '';
  if (value === null || value === undefined || value === '') {
    return fieldName ? '暂无' + fieldName : '暂无数据';
  }
  return value;
};

var formatTime = function(value) {
  if (value === null || value === undefined || value === '') {
    return '--';
  }
  return value;
};

module.exports = {
  formatNumber: formatNumber,
  formatText: formatText,
  formatTime: formatTime
};
</wxs>
<view class="container">
  <view class="warning-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">预警详情</view>
    <view class="placeholder"></view>
  </view>

  <view class="warning-detail" wx:if="{{warning}}">
    <view class="detail-header">
      <view class="warning-type-icon {{warning.type}}">
        {{format.formatText(warning.icon, '')}}
      </view>
      <view class="warning-info">
        <view class="warning-title">{{format.formatText(warning.title, '预警标题')}}</view>
        <view class="warning-time">{{format.formatTime(warning.time)}}</view>
      </view>
      <view class="warning-status {{warning.status}}">
        {{warning.status === 'unhandled' ? '未处理' : (warning.status === 'handled' ? '已处理' : format.formatText('', '处理状态'))}}
      </view>
    </view>

    <view class="detail-card">
      <view class="detail-title">预警详情</view>
      <view class="detail-item">
        <text class="detail-label">预警类型</text>
        <text class="detail-value">{{format.formatText(warning.typeText, '预警类型')}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">发生时间</text>
        <text class="detail-value">{{format.formatTime(warning.time)}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">发生位置</text>
        <text class="detail-value">{{format.formatText(warning.location, '位置')}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">严重程度</text>
        <text class="detail-value severity-{{warning.severity}}">
          {{warning.severity === 'high' ? '高' : (warning.severity === 'medium' ? '中' : format.formatText('低', '严重程度'))}}
        </text>
      </view>
    </view>

    <view class="detail-card" wx:if="{{warning.description}}">
      <view class="detail-title">详细描述</view>
      <view class="description-text">{{format.formatText(warning.description, '描述')}}</view>
    </view>

    <view class="detail-card" wx:if="{{warning.handleRecords && warning.handleRecords.length > 0}}">
      <view class="detail-title">处理记录</view>
      <view class="record-item" wx:for="{{warning && warning.handleRecords ? warning.handleRecords : []}}" wx:key="index">
        <view class="record-time">{{format.formatTime(item.time)}}</view>
        <view class="record-content">{{format.formatText(item.content, '记录内容')}}</view>
      </view>
    </view>

    <view class="action-section" wx:if="{{warning.status === 'unhandled'}}">
      <button class="handle-btn" bindtap="handleWarning">标记已处理</button>
      <view class="action-hint">确认该预警已得到妥善处理</view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon">⚠️</view>
    <view class="empty-title">预警不存在</view>
    <view class="empty-desc">该预警可能已被删除或处理</view>
    <button class="back-btn-lg" bindtap="goBack">返回预警列表</button>
  </view>
</view>