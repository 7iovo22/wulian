.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 30%, var(--color-bg-secondary) 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 卡通装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 120rpx;
  right: -80rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 150rpx;
  left: -60rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.warning-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: transparent;
  position: relative;
  z-index: 10;
}

.back-btn, .placeholder {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.35);
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.warning-detail {
  padding: 20rpx;
  position: relative;
  z-index: 10;
}

.detail-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.5s ease-out;
  position: relative;
  overflow: hidden;
}

.detail-header::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.2;
}

.warning-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  position: relative;
  z-index: 5;
}

.warning-type-icon::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--color-cute-orange);
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}

.warning-type-icon.fatigue {
  background: linear-gradient(135deg, var(--color-cute-orange) 0%, var(--color-warning-light) 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 204, 128, 0.3);
}

.warning-type-icon.collision, .warning-type-icon.fall, .warning-type-icon.sos {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
  box-shadow: 0 4rpx 12rpx rgba(248, 187, 208, 0.3);
}

.warning-type-icon.temperature, .warning-type-icon.heartrate {
  background: linear-gradient(135deg, var(--color-cute-purple) 0%, #BA68C8 100%);
  box-shadow: 0 4rpx 12rpx rgba(206, 147, 216, 0.3);
}

.warning-type-icon.speed {
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
  box-shadow: 0 4rpx 12rpx rgba(165, 214, 167, 0.3);
}

.warning-type-icon.zone {
  background: var(--color-primary-gradient);
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.3);
}

.warning-info {
  flex: 1;
  position: relative;
  z-index: 5;
}

.warning-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.warning-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.warning-status {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  position: relative;
  z-index: 5;
}

.warning-status.unhandled {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(248, 187, 208, 0.3);
}

.warning-status.handled {
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(165, 214, 167, 0.3);
}

.detail-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.6s ease-out;
  position: relative;
  overflow: hidden;
}

.detail-card::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.15;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
}

.detail-title::after {
  content: '📌';
  position: absolute;
  right: 0rpx;
  top: 0rpx;
  font-size: 24rpx;
  opacity: 0.4;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  position: relative;
  z-index: 5;
}

.detail-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.detail-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: bold;
}

.detail-value.severity-high {
  color: var(--color-danger);
}

.detail-value.severity-medium {
  color: var(--color-warning);
}

.detail-value.severity-low {
  color: var(--color-primary);
}

.description-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  position: relative;
  z-index: 5;
}

.record-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
  z-index: 5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.record-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.action-section {
  margin-top: 30rpx;
  text-align: center;
  position: relative;
  z-index: 10;
}

.handle-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-medium);
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.handle-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-light);
}

.handle-btn::before {
  content: '✨';
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
}

.action-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
  animation: fadeIn 0.8s ease-out;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.back-btn-lg {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: var(--shadow-medium);
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.back-btn-lg:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-light);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}