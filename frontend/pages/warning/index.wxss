.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.warning-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
}

.back-btn, .placeholder {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.warning-detail {
  padding: 20rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.warning-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  background: #FFF0F0;
}

.warning-type-icon.fatigue {
  background: #FFF9E6;
}

.warning-type-icon.collision, .warning-type-icon.fall, .warning-type-icon.sos {
  background: #FFE0E0;
}

.warning-type-icon.temperature, .warning-type-icon.heartrate {
  background: #FFE8E8;
}

.warning-type-icon.speed {
  background: #FFF3E0;
}

.warning-type-icon.zone {
  background: #E3F2FD;
}

.warning-info {
  flex: 1;
}

.warning-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.warning-time {
  font-size: 24rpx;
  color: #999999;
}

.warning-status {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.warning-status.unhandled {
  background: #FFE0E0;
  color: #DC143C;
}

.warning-status.handled {
  background: #E8F8E8;
  color: #32CD32;
}

.detail-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
}

.detail-label {
  font-size: 28rpx;
  color: #999999;
}

.detail-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.detail-value.severity-high {
  color: #DC143C;
}

.detail-value.severity-medium {
  color: #FFA500;
}

.detail-value.severity-low {
  color: #1E90FF;
}

.description-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.record-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.record-content {
  font-size: 28rpx;
  color: #333333;
}

.action-section {
  margin-top: 30rpx;
  text-align: center;
}

.handle-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  margin-bottom: 20rpx;
}

.action-hint {
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 40rpx;
}

.back-btn-lg {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}