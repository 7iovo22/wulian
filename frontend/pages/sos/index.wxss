.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.sos-header {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #DC143C 0%, #FF4444 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.sos-status {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.sos-status.active .status-icon {
  animation: pulse 1s infinite;
}

.status-icon {
  font-size: 40rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.sos-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx;
}

.sos-button {
  width: 280rpx;
  height: 280rpx;
  background: linear-gradient(135deg, #DC143C 0%, #FF4444 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 50rpx rgba(220, 20, 60, 0.4);
  margin-bottom: 30rpx;
}

.sos-inner {
  width: 220rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sos-icon {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.sos-hint {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.quick-actions {
  display: flex;
  gap: 30rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.action-icon.police {
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
}

.action-icon.ambulance {
  background: linear-gradient(135deg, #32CD32 0%, #90EE90 100%);
}

.action-icon.contact {
  background: linear-gradient(135deg, #FF8C00 0%, #FFA500 100%);
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.sos-active {
  padding: 30rpx;
}

.active-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.active-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.active-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #DC143C;
  margin-bottom: 10rpx;
}

.active-desc {
  font-size: 26rpx;
  color: #999999;
}

.active-info {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 36rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 5rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.info-value.success {
  color: #32CD32;
}

.recording-section {
  background: #FFF0F0;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.recording-status {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.recording-dot {
  width: 16rpx;
  height: 16rpx;
  background: #DC143C;
  border-radius: 50%;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.recording-text {
  font-size: 28rpx;
  color: #DC143C;
  font-weight: bold;
}

.recording-wave {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  height: 40rpx;
  align-items: center;
}

.wave-bar {
  width: 8rpx;
  height: 100%;
  background: #DC143C;
  border-radius: 4rpx;
  animation: wave 0.5s infinite ease-in-out;
}

@keyframes wave {
  0%, 100% { height: 20%; }
  50% { height: 100%; }
}

.cancel-section {
  text-align: center;
}

.cancel-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #DC143C 0%, #FF4444 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-bottom: 20rpx;
}

.cancel-hint {
  font-size: 24rpx;
  color: #999999;
}

.tips-section {
  padding: 0 20rpx;
}

.tips-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 25rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}