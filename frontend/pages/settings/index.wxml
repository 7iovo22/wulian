<view class="container">
  <view class="section">
    <view class="section-title">👤 个人信息</view>
    <view class="card">
      <view class="form-item">
        <view class="form-label">头像</view>
        <view class="avatar-upload" bindtap="chooseAvatar">
          <image src="{{formData && formData.avatar ? formData.avatar : 'https://picsum.photos/120/120'}}" mode="aspectFill" class="avatar-preview"></image>
          <view class="upload-icon">+</view>
        </view>
      </view>
      
      <view class="form-item">
        <view class="form-label">昵称</view>
        <input class="form-input" placeholder="请输入昵称" value="{{formData.nickname}}" bindinput="onNicknameInput" />
      </view>
      
      <view class="form-item">
        <view class="form-label">性别</view>
        <view class="gender-options">
          <view class="gender-option {{formData.gender === 'male' ? 'active' : ''}}" bindtap="setGender" data-gender="male">
            <text class="gender-icon">👨</text>
            <text>男</text>
          </view>
          <view class="gender-option {{formData.gender === 'female' ? 'active' : ''}}" bindtap="setGender" data-gender="female">
            <text class="gender-icon">👩</text>
            <text>女</text>
          </view>
          <view class="gender-option {{formData.gender === '' ? 'active' : ''}}" bindtap="setGender" data-gender="">
            <text class="gender-icon">👤</text>
            <text>保密</text>
          </view>
        </view>
      </view>
    </view>
    
    <button class="save-btn" bindtap="saveUserInfo">保存个人信息</button>
  </view>

  <view class="section">
    <view class="section-title">📱 手机号绑定</view>
    <view class="card">
      <view class="phone-info" wx:if="{{formData.phone}}">
        <view class="phone-label">已绑定手机号</view>
        <view class="phone-value">{{formData.phone}}</view>
        <view class="change-btn" bindtap="showChangePhone">更换手机号</view>
      </view>
      
      <view class="phone-form" wx:else>
        <view class="form-item">
          <view class="form-label">手机号</view>
          <input class="form-input" placeholder="请输入手机号" type="number" value="{{phoneForm.phone}}" bindinput="onPhoneInput" />
        </view>
        
        <view class="form-item">
          <view class="form-label">验证码</view>
          <view class="code-row">
            <input class="form-input code-input" placeholder="请输入验证码" type="number" value="{{phoneForm.code}}" bindinput="onCodeInput" maxlength="6" />
            <button class="get-code-btn" bindtap="getCode" disabled="{{countdown > 0}}">
              {{countdown > 0 ? countdown + 's' : '获取验证码'}}
            </button>
          </view>
        </view>
        
        <button class="bind-btn" bindtap="bindPhone">绑定手机号</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">⚙️ 其他设置</view>
    <view class="menu-group">
      <view class="menu-item">
        <view class="menu-icon">🔔</view>
        <text class="menu-text">消息通知</text>
        <switch class="menu-switch" checked="{{settings.notifications}}" bindchange="onNotificationChange" />
      </view>
      <view class="menu-item">
        <view class="menu-icon">🌙</view>
        <text class="menu-text">深色模式</text>
        <switch class="menu-switch" checked="{{settings.darkMode}}" bindchange="onDarkModeChange" />
      </view>
      <view class="menu-item">
        <view class="menu-icon">🔒</view>
        <text class="menu-text">修改密码</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item">
        <view class="menu-icon">📊</view>
        <text class="menu-text">数据统计</text>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">📋 关于</view>
    <view class="menu-group">
      <view class="menu-item">
        <view class="menu-icon">ℹ️</view>
        <text class="menu-text">关于我们</text>
        <text class="menu-value">骑安智盔 v1.0.0</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">📝</view>
        <text class="menu-text">用户协议</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item">
        <view class="menu-icon">🔏</view>
        <text class="menu-text">隐私政策</text>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>

  <view class="change-phone-modal" wx:if="{{showChangeModal}}">
    <view class="modal-mask" bindtap="hideChangePhone"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">更换手机号</text>
        <view class="close-btn" bindtap="hideChangePhone">✕</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">原手机号</view>
          <view class="form-value">{{formData.phone}}</view>
        </view>
        <view class="form-item">
          <view class="form-label">新手机号</view>
          <input class="form-input" placeholder="请输入新手机号" type="number" value="{{changePhoneForm.phone}}" bindinput="onChangePhoneInput" />
        </view>
        <view class="form-item">
          <view class="form-label">验证码</view>
          <view class="code-row">
            <input class="form-input code-input" placeholder="请输入验证码" type="number" value="{{changePhoneForm.code}}" bindinput="onChangeCodeInput" />
            <button class="get-code-btn" bindtap="getChangeCode" disabled="{{changeCountdown > 0}}">
              {{changeCountdown > 0 ? changeCountdown + 's' : '获取验证码'}}
            </button>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideChangePhone">取消</button>
        <button class="btn-confirm" bindtap="changePhone">确认更换</button>
      </view>
    </view>
  </view>
</view>