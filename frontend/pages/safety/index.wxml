<wxs module="format">
var formatNumber = function(value) {
  if (value === null || value === undefined || value === '') {
    return '--';
  }
  var num = parseFloat(value);
  return isNaN(num) ? '--' : value;
};

var formatText = function(value, fieldName) {
  fieldName = fieldName || '';
  if (value === null || value === undefined || value === '') {
    return fieldName ? '暂无' + fieldName : '暂无数据';
  }
  return value;
};

var formatTime = function(value) {
  if (value === null || value === undefined || value === '') {
    return '--';
  }
  return value;
};

module.exports = {
  formatNumber: formatNumber,
  formatText: formatText,
  formatTime: formatTime
};
</wxs>
<view class="container">
  <view class="sos-section">
    <view class="sos-card" bindlongpress="triggerSOS" bindtap="onSOSClick">
      <view class="sos-icon">
        <text class="sos-text">SOS</text>
      </view>
      <view class="sos-tip">长按0.5秒触发紧急求助</view>
    </view>
  </view>

  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-value">{{format.formatNumber(stats.total)}}</view>
        <view class="stat-label">预警总数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value warning">{{format.formatNumber(stats.unhandled)}}</view>
        <view class="stat-label">待处理</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value success">{{format.formatNumber(stats.handled)}}</view>
        <view class="stat-label">已处理</view>
      </view>
    </view>
  </view>

  <view class="warning-section">
    <view class="section-header">
      <text class="section-title">安全事件列表</text>
      <text class="section-filter" bindtap="showFilter">筛选 →</text>
    </view>
    
    <view class="warning-list">
      <view 
        class="warning-item" 
        wx:for="{{warningList}}" 
        wx:key="id"
        bindtap="viewWarningDetail"
        data-id="{{item.id}}"
      >
        <view class="warning-left">
          <view class="warning-icon" style="background: {{getEventColor(item.eventType)}};">
            <text>{{getEventIcon(item.eventType)}}</text>
          </view>
          <view class="risk-badge" style="background: {{getRiskColor(item.riskLevel)}};">
            {{getRiskText(item.riskLevel)}}
          </view>
        </view>
        <view class="warning-content">
          <view class="warning-header">
            <view class="type-tag" style="background: {{getEventTypeBg(item.eventType)}}; color: {{getEventTypeColor(item.eventType)}};">
              {{getEventTypeText(item.eventType)}}
            </view>
            <text class="warning-time">{{format.formatTime(item.createTime)}}</text>
          </view>
          <view class="warning-desc">{{format.formatText(item.description, '事件描述')}}</view>
          <view class="warning-footer">
            <text class="warning-location">📍 {{format.formatText(item.desensitizedLocation, '位置')}}</text>
            <view class="status-badge {{item.statusClass}}">
              {{getStatusText(item.status)}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{warningList.length === 0}}">
      <view class="empty-icon">✓</view>
      <view class="empty-text">暂无安全事件记录</view>
      <view class="empty-hint">您的骑行状态良好</view>
    </view>
  </view>

  <view class="quick-section">
    <view class="section-title">快捷功能</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToHealth">
        <view class="quick-icon health">❤</view>
        <text class="quick-text">健康监测</text>
      </view>
      <view class="quick-item" bindtap="goToAIAnalysis">
        <view class="quick-icon ai">🤖</view>
        <text class="quick-text">AI分析</text>
      </view>
      <view class="quick-item" bindtap="goToReminder">
        <view class="quick-icon reminder">🔔</view>
        <text class="quick-text">生活提醒</text>
      </view>
      <view class="quick-item" bindtap="goToDailyReport">
        <view class="quick-icon report">📊</view>
        <text class="quick-text">安全报告</text>
      </view>
    </view>
  </view>

  <view class="fall-detection-modal" wx:if="{{showFallModal}}">
    <view class="modal-mask" bindtap="cancelFallAlarm"></view>
    <view class="modal-content">
      <view class="modal-icon">⚠️</view>
      <view class="modal-title">检测到异常</view>
      <view class="modal-desc">系统检测到可能的摔倒，您还好吗？</view>
      <view class="modal-countdown">
        <view class="countdown-ring" style="background: conic-gradient(#DC143C 0deg, #DC143C {{countdownAngle}}deg, #E8F4FC {{countdownAngle}}deg, #E8F4FC 360deg);">
          <view class="countdown-inner">
            <text class="countdown-num">{{countdown}}</text>
            <text class="countdown-unit">秒</text>
          </view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="modal-btn cancel" bindtap="cancelFallAlarm">我没事</button>
        <button class="modal-btn confirm" bindtap="confirmFallAlarm">确认报警</button>
      </view>
    </view>
  </view>
</view>