.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: 120rpx;
}

.sos-section {
  padding: 30rpx 20rpx;
}

.sos-card {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  box-shadow: var(--shadow-medium);
  position: relative;
  overflow: hidden;
}

.sos-card::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.sos-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.sos-icon {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 2s infinite ease-in-out;
  position: relative;
}

.sos-icon::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.sos-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-bg-primary);
  letter-spacing: 2rpx;
}

.sos-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.stats-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: var(--shadow-light);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.stat-value.warning {
  color: var(--color-warning);
}

.stat-value.success {
  color: var(--color-success);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 5rpx;
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  background: var(--color-border-light);
}

.warning-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
}

.section-filter {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.warning-item {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 25rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: var(--shadow-light);
  transition: all 0.3s ease;
}

.warning-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-medium);
}

.warning-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.warning-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.risk-badge {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.warning-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.warning-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.type-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.warning-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.warning-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.warning-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.warning-location {
  font-size: 22rpx;
  color: var(--color-text-disabled);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.status-badge.open {
  background: rgba(255, 140, 0, 0.1);
  color: #FF8C00;
}

.status-badge.acked {
  background: rgba(30, 144, 255, 0.1);
  color: #1E90FF;
}

.status-badge.resolved {
  background: rgba(50, 205, 50, 0.1);
  color: #32CD32;
}

.status-badge.cancelled {
  background: rgba(120, 144, 156, 0.1);
  color: #78909C;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--color-bg-primary);
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.quick-section {
  padding: 0 20rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 25rpx;
  box-shadow: var(--shadow-light);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.quick-icon:active {
  transform: scale(0.9);
}

.quick-icon.health {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
}

.quick-icon.ai {
  background: linear-gradient(135deg, var(--color-cute-purple) 0%, #CE93D8 100%);
}

.quick-icon.reminder {
  background: linear-gradient(135deg, #FFD54F 0%, #FFB74D 100%);
}

.quick-icon.report {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
}

.quick-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.fall-detection-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow-heavy);
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

.modal-icon {
  font-size: 80rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
}

.modal-countdown {
  margin-top: 10rpx;
}

.countdown-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
}

.countdown-inner {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-bg-primary);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.countdown-num {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-danger);
}

.countdown-unit {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.modal-btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.modal-btn.cancel {
  background: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
  color: var(--color-bg-primary);
  box-shadow: 0 4rpx 12rpx rgba(239, 83, 80, 0.3);
}