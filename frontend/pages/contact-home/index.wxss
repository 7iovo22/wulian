.page-container {
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: #F0F4F8;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #4FC3F7;
}

.navbar-status-bar {
  height: var(--status-bar-height, 44px);
}

.navbar-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.header {
  background: linear-gradient(135deg, #4FC3F7 0%, #29B6F6 100%);
  padding: 140rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-right {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 48rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.notification-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.notification-icon {
  font-size: 32rpx;
}

.notification-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  background: #EF5350;
  border-radius: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #FFFFFF;
  margin: -20rpx 24rpx 24rpx;
  padding: 32rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #4FC3F7;
  margin-bottom: 8rpx;
}

.alarm-value {
  color: #EF5350;
}

.online-value {
  color: #52C41A;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #EEEEEE;
}

.section-header {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}

.rider-list {
  padding: 0 24rpx;
}

.rider-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rider-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.rider-avatar {
  width: 80rpx;
  height: 80rpx;
  background: #E3F2FD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
}

.rider-avatar-icon {
  font-size: 36rpx;
}

.online-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}

.online-dot.online {
  background: #52C41A;
}

.online-dot.offline {
  background: #999999;
}

.rider-detail {
  display: flex;
  flex-direction: column;
}

.rider-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.rider-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 12rpx;
}

.relation-tag {
  font-size: 22rpx;
  color: #4FC3F7;
  background: #E3F2FD;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.rider-meta {
  display: flex;
  align-items: center;
}

.rider-phone {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.activity-time {
  font-size: 22rpx;
  color: #999999;
}

.rider-status {
  display: flex;
  align-items: center;
}

.safety-tag {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.contact-btn {
  width: 64rpx;
  height: 64rpx;
  background: #E3F2FD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-icon {
  font-size: 28rpx;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 40rpx;
}

.nav-item.active .nav-icon {
  color: #4FC3F7;
}

.nav-item.active .nav-text {
  color: #4FC3F7;
  font-weight: 500;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  color: #999999;
}

.nav-text {
  font-size: 24rpx;
  color: #999999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.detail-modal {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  padding: 40rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: #333;
}

.modal-status {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-content {
  padding: 0 32rpx 32rpx;
}

.modal-rider-info {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.modal-avatar {
  width: 100rpx;
  height: 100rpx;
  background: #E3F2FD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-right: 24rpx;
}

.modal-avatar-icon {
  font-size: 48rpx;
}

.modal-basic {
  flex: 1;
}

.modal-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.modal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.modal-phone {
  font-size: 26rpx;
  color: #999;
}

.modal-call-btn {
  width: 88rpx;
  height: 88rpx;
  background: #4FC3F7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-call-icon {
  font-size: 40rpx;
}

.modal-info-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.modal-info-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-score-display {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.modal-score-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
}

.modal-score-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 8rpx;
}

.modal-score-bar {
  height: 12rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  overflow: hidden;
}

.modal-score-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.modal-location {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.modal-location-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.modal-location-text {
  font-size: 28rpx;
  color: #333;
}

.modal-location-time {
  font-size: 24rpx;
  color: #999;
}

.modal-alarm {
  display: flex;
  align-items: baseline;
}

.modal-alarm-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF4D4F;
}

.modal-alarm-label {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.modal-online {
  display: flex;
  align-items: center;
}

.online-dot-large {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.online-dot-large.online {
  background: #52C41A;
}

.online-dot-large.offline {
  background: #999;
}

.modal-online-text {
  font-size: 28rpx;
  color: #333;
}