<view class="container">
  <view class="mine-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="user-card">
        <image src="{{userInfo.avatar || 'https://picsum.photos/120/120'}}" mode="aspectFill" class="user-avatar"></image>
        <view class="user-info">
        <view class="user-name">{{userInfo.nickname || '骑手'}}</view>
        <view class="user-phone" bindtap="editUserInfo">{{userInfo.phone || '请绑定手机号'}}</view>
      </view>
        <view class="edit-btn" bindtap="editUserInfo">
          <text class="edit-icon">✏️</text>
        </view>
      </view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-card" bindtap="goToRides">
      <view class="stat-value">{{stats.rides}}</view>
      <view class="stat-label">累计骑行</view>
    </view>
    <view class="stat-card" bindtap="goToHealth">
      <view class="stat-value">{{stats.distance}}km</view>
      <view class="stat-label">累计里程</view>
    </view>
    <view class="stat-card" bindtap="goToWarning">
      <view class="stat-value">{{stats.warnings}}</view>
      <view class="stat-label">预警次数</view>
    </view>
    <view class="stat-card" bindtap="goToSafety">
      <view class="stat-value">{{stats.score}}</view>
      <view class="stat-label">安全评分</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToDevice">
        <view class="menu-icon">📱</view>
        <text class="menu-text">设备管理</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToContacts">
        <view class="menu-icon">👥</view>
        <text class="menu-text">紧急联系人</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToHealth">
        <view class="menu-icon">❤️</view>
        <text class="menu-text">健康监测</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToReport">
        <view class="menu-icon">📊</view>
        <text class="menu-text">安全报告</text>
        <view class="menu-arrow">→</view>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon">⚙️</view>
        <text class="menu-text">设置</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToHelp">
        <view class="menu-icon">❓</view>
        <text class="menu-text">帮助与反馈</text>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-icon">ℹ️</view>
        <text class="menu-text">关于我们</text>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>

  <view class="bind-section" wx:if="!hasDevice">
    <view class="bind-card" bindtap="goToBind">
      <view class="bind-icon">🔗</view>
      <view class="bind-content">
        <view class="bind-title">绑定设备</view>
        <view class="bind-desc">绑定智能头盔，开启安全守护</view>
      </view>
      <view class="bind-arrow">→</view>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>