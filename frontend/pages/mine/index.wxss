.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: 120rpx;
}

.mine-header {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: 40rpx;
  right: -60rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: 100rpx;
  left: -80rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 25rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  animation: fadeIn 0.6s ease-out;
}

.user-card::before {
  content: '✨';
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 24rpx;
  opacity: 0.5;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(79, 195, 247, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.2);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.user-phone {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.edit-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.2);
  transition: all 0.3s ease;
}

.edit-btn:active {
  transform: scale(0.9);
}

.edit-icon {
  font-size: 28rpx;
  color: #FFFFFF;
}

.stats-row {
  display: flex;
  margin: -20rpx 20rpx 20rpx;
  gap: 15rpx;
}

.stat-card {
  flex: 1;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  padding: 28rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-light);
  position: relative;
  overflow: hidden;
  animation: fadeIn 0.6s ease-out;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.2;
}

.stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  font-weight: 500;
}

.menu-section {
  padding: 0 20rpx;
}

.menu-group {
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 20rpx;
  margin-bottom: 15rpx;
  overflow: hidden;
  box-shadow: var(--shadow-light);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all 0.3s ease;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--color-bg-tertiary);
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--color-text-disabled);
}

.bind-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.bind-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-medium);
  animation: fadeIn 0.6s ease-out;
}

.bind-card::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.bind-card::after {
  content: '⭐';
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  font-size: 28rpx;
  opacity: 0.6;
}

.bind-icon {
  font-size: 48rpx;
}

.bind-content {
  flex: 1;
}

.bind-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.bind-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.bind-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
}

.logout-section {
  padding: 40rpx 20rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F4F8 100%);
  color: var(--color-text-secondary);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: var(--shadow-light);
  transition: all 0.3s ease;
}

.logout-btn:active {
  transform: scale(0.98);
  background: var(--color-bg-tertiary);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}