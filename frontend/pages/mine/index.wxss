.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.mine-header {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 25rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #F0F0F0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #999999;
}

.edit-btn {
  width: 60rpx;
  height: 60rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon {
  font-size: 28rpx;
}

.stats-row {
  display: flex;
  margin: -20rpx 20rpx 20rpx;
  gap: 15rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 25rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E90FF;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}

.menu-section {
  padding: 0 20rpx;
}

.menu-group {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 15rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.bind-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.bind-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #1E90FF 0%, #00BFFF 100%);
  border-radius: 16rpx;
  padding: 30rpx;
}

.bind-icon {
  font-size: 48rpx;
}

.bind-content {
  flex: 1;
}

.bind-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.bind-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.bind-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
}

.logout-section {
  padding: 40rpx 20rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  color: #666666;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}