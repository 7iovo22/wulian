.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 30%, var(--color-bg-secondary) 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 卡通装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 100rpx;
  right: -60rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  left: -40rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.contacts-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: transparent;
  position: relative;
  z-index: 10;
}

.back-btn, .add-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  transition: all 0.3s ease;
}

.back-btn:active, .add-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.35);
}

.back-icon, .add-icon {
  font-size: 40rpx;
  color: #FFFFFF;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.contacts-list {
  padding: 20rpx;
  position: relative;
  z-index: 10;
}

.contact-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 24rpx;
  padding: 25rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s ease;
  animation: fadeIn 0.5s ease-out;
  position: relative;
  overflow: hidden;
}

.contact-item::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--color-cute-blue);
  border-radius: 50%;
  opacity: 0.2;
}

.contact-item:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-medium);
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.3);
  position: relative;
}

.contact-avatar::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 20rpx;
  height: 20rpx;
  background: var(--color-cute-orange);
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.contact-info {
  flex: 1;
  position: relative;
  z-index: 5;
}

.contact-name {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 8rpx;
}

.contact-name text {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.contact-relation {
  padding: 5rpx 15rpx;
  background: linear-gradient(135deg, var(--color-cute-blue) 0%, var(--color-primary-light) 100%);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.contact-phone {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.contact-actions {
  display: flex;
  gap: 20rpx;
  position: relative;
  z-index: 5;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.3s ease;
  box-shadow: var(--shadow-light);
}

.action-btn:active {
  transform: scale(0.9);
}

.action-btn.call {
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
}

.action-btn.edit {
  background: linear-gradient(135deg, var(--color-cute-orange) 0%, var(--color-warning-light) 100%);
}

.action-btn.delete {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  animation: fadeIn 0.8s ease-out;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.add-btn-lg {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: var(--shadow-medium);
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.add-btn-lg:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-light);
}

.add-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8F9FA 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.3s ease-out;
}

.modal-content::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 8rpx;
  background: var(--color-bg-tertiary);
  border-radius: 4rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
}

.modal-header::after {
  content: '💫';
  position: absolute;
  right: 80rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  opacity: 0.4;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
}

.close-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-secondary);
  border-radius: 50%;
  background: var(--color-bg-secondary);
  transition: all 0.3s ease;
}

.close-btn:active {
  background: var(--color-bg-tertiary);
  transform: scale(0.9);
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 15rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-bg-secondary) 100%);
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--color-border-light);
  color: var(--color-text-primary);
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-light);
}

.relation-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.relation-option {
  padding: 15rpx 30rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-bg-secondary) 100%);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border-light);
  transition: all 0.3s ease;
  font-weight: 500;
}

.relation-option.active {
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: var(--shadow-light);
}

.relation-option:active {
  transform: scale(0.95);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.btn-cancel {
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-bg-secondary) 100%);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
}

.btn-cancel:active {
  background: var(--color-bg-tertiary);
  transform: scale(0.96);
}

.btn-confirm {
  background: var(--color-primary-gradient);
  color: #FFFFFF;
  box-shadow: var(--shadow-medium);
}

.btn-confirm:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-light);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}