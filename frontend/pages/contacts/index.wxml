<view class="container">
  <view class="contacts-header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">紧急联系人</view>
    <view class="add-btn" bindtap="addContact">
      <text class="add-icon">+</text>
    </view>
  </view>

  <view class="contacts-list" wx:if="{{contacts.length > 0}}">
    <view class="contact-item" wx:for="{{contacts}}" wx:key="id">
      <view class="contact-avatar">
        <text class="avatar-text">{{item.name.charAt(0)}}</text>
      </view>
      <view class="contact-info">
        <view class="contact-name">
          <text>{{item.name}}</text>
          <text class="contact-relation">{{item.relation}}</text>
        </view>
        <view class="contact-phone">{{item.phone}}</view>
      </view>
      <view class="contact-actions">
        <view class="action-btn call" bindtap="callContact" data-phone="{{item.phone}}">
          <text>📞</text>
        </view>
        <view class="action-btn edit" bindtap="editContact" data-id="{{item.id}}">
          <text>✏️</text>
        </view>
        <view class="action-btn delete" bindtap="deleteContact" data-id="{{item.id}}">
          <text>🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon">📞</view>
    <view class="empty-title">暂无紧急联系人</view>
    <view class="empty-desc">添加紧急联系人，在紧急情况下会收到求助通知</view>
    <button class="add-btn-lg" bindtap="addContact">添加联系人</button>
  </view>

  <view class="add-modal" wx:if="{{showAddModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{editingContact ? '编辑联系人' : '添加联系人'}}</text>
        <view class="close-btn" bindtap="closeModal">✕</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">姓名</text>
          <input 
            class="form-input" 
            placeholder="请输入姓名" 
            value="{{formData.name}}" 
            bindinput="onNameInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">关系</text>
          <view class="relation-options">
            <view 
              class="relation-option {{formData.relation === '父母' ? 'active' : ''}}" 
              bindtap="setRelation" 
              data-relation="父母"
            >父母</view>
            <view 
              class="relation-option {{formData.relation === '配偶' ? 'active' : ''}}" 
              bindtap="setRelation" 
              data-relation="配偶"
            >配偶</view>
            <view 
              class="relation-option {{formData.relation === '子女' ? 'active' : ''}}" 
              bindtap="setRelation" 
              data-relation="子女"
            >子女</view>
            <view 
              class="relation-option {{formData.relation === '朋友' ? 'active' : ''}}" 
              bindtap="setRelation" 
              data-relation="朋友"
            >朋友</view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">手机号</text>
          <input 
            class="form-input" 
            placeholder="请输入手机号" 
            type="number"
            value="{{formData.phone}}" 
            bindinput="onPhoneInput"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="saveContact">保存</button>
      </view>
    </view>
  </view>
</view>