.container {
  min-height: 100vh;
  background: var(--color-bg-secondary);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.date-selector {
  background: var(--color-bg-primary);
  padding: 20rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.date-item.active {
  background: var(--color-primary-gradient);
  transform: scale(1.05);
}

.date-label {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.date-item.active .date-label {
  color: #fff;
}

.date-weekday {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.date-item.active .date-weekday {
  color: rgba(255, 255, 255, 0.85);
}

.loading-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-icon {
  font-size: 64rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.score-section {
  margin: 20rpx;
  background: linear-gradient(135deg, var(--color-cute-blue) 0%, var(--color-primary-light) 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx 30rpx;
  box-shadow: var(--shadow-medium);
  position: relative;
  overflow: hidden;
}

.score-section::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.score-section::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.score-main {
  display: flex;
  align-items: center;
  gap: 30rpx;
  position: relative;
  z-index: 1;
}

.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-inner {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  line-height: 1;
}

.score-unit {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.score-info {
  flex: 1;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.score-level {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.score-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-primary);
  margin: 0 20rpx 20rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-light);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: bold;
  background: rgba(79, 195, 247, 0.08);
}

.tab-content {
  padding: 0 20rpx;
}

.card {
  background: linear-gradient(135deg, var(--color-bg-primary) 0%, #F8F9FA 100%);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-light);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 10rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.stat-icon {
  font-size: 36rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.title-icon {
  font-size: 32rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  flex: 1;
}

.event-count {
  font-size: 24rpx;
  color: var(--color-primary);
  background: rgba(79, 195, 247, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-weight: 500;
}

.trend-chart {
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  margin-bottom: 16rpx;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-inner {
  width: 32rpx;
  border-radius: 16rpx 16rpx 0 0;
  min-height: 8rpx;
  transition: height 0.5s ease;
}

.bar-value {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.chart-labels {
  display: flex;
  justify-content: space-around;
}

.chart-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.ai-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
}

.ai-badge.active {
  background: linear-gradient(135deg, #81C784 0%, #4CAF50 100%);
  color: #fff;
}

.ai-badge.mock {
  background: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
}

.ai-content {
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: 24rpx;
}

.summary-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.summary-text.truncated {
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.toggle-btn {
  text-align: center;
  color: var(--color-primary);
  font-size: 26rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.ai-mock {
  text-align: center;
  padding: 20rpx 0;
}

.mock-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.generate-btn {
  background: var(--color-primary-gradient);
  color: #fff;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommendation-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rec-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.rec-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  padding-top: 4rpx;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.event-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.event-item:active {
  transform: scale(0.98);
}

.event-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.event-content {
  flex: 1;
  min-width: 0;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.event-type {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.event-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.event-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-location {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.event-level {
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-cute-green) 0%, var(--color-success-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.health-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.health-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.health-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.health-icon.heart {
  background: linear-gradient(135deg, var(--color-cute-pink) 0%, var(--color-danger-light) 100%);
}

.health-icon.temp {
  background: linear-gradient(135deg, var(--color-cute-orange) 0%, var(--color-warning-light) 100%);
}

.health-icon.fatigue {
  background: linear-gradient(135deg, var(--color-cute-purple) 0%, #CE93D8 100%);
}

.health-icon.max {
  background: linear-gradient(135deg, var(--color-cute-blue) 0%, var(--color-primary-light) 100%);
}

.health-info {
  flex: 1;
}

.health-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.health-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.health-unit {
  font-size: 20rpx;
  color: var(--color-text-disabled);
}

.device-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.device-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
}

.device-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.device-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.device-value.status-normal {
  color: #4CAF50;
}

.device-value.status-error {
  color: #E57373;
}

.battery-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.battery-bar {
  width: 120rpx;
  height: 24rpx;
  background: var(--color-border-light);
  border-radius: 12rpx;
  overflow: hidden;
}

.battery-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50 0%, #81C784 100%);
  border-radius: 12rpx;
  transition: width 0.5s ease;
}

.battery-text {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  min-width: 60rpx;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, var(--color-bg-secondary) 80%, transparent);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.action-btn.secondary {
  background: var(--color-bg-primary);
  color: var(--color-text-secondary);
  box-shadow: var(--shadow-light);
}

.action-btn.primary {
  background: var(--color-primary-gradient);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.3);
}

.btn-icon {
  font-size: 28rpx;
}
