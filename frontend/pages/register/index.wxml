<view class="container">
  <view class="login-header">
    <view class="logo">
      <image src="https://picsum.photos/120/120" mode="aspectFill" class="logo-img"></image>
    </view>
    <view class="title">紧急联系人注册</view>
    <view class="subtitle">为骑手提供安全守护</view>
  </view>

  <view class="login-form">
    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入手机号" 
        bindinput="onPhoneInput"
        maxlength="11"
        type="number"
        value="{{phone}}"
      />
    </view>

    <view class="form-item">
      <input 
        class="input" 
        placeholder="请输入密码（6-20位）" 
        bindinput="onPasswordInput"
        maxlength="20"
        type="text"
        password="{{true}}"
        value="{{password}}"
      />
    </view>

    <view class="form-item">
      <input 
        class="input" 
        placeholder="请确认密码" 
        bindinput="onConfirmPasswordInput"
        maxlength="20"
        type="text"
        password="{{true}}"
        value="{{confirmPassword}}"
      />
    </view>

    <button class="btn-primary login-btn" bindtap="register">注册</button>
    
    <view class="login-tips">
      <text>注册即表示同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>

  <view class="login-bottom">
    <view class="return-login">
      <text class="text-link" bindtap="goToLogin">返回登录</text>
    </view>
  </view>
</view>